#, php-format
msgid "Plan proposal: %1$s (%2$s)"
msgstr "计划提案：%1$s（%2$s）"

#. translators: 1: plan ability id, 2: batch id.
#: includes/Governance/Plan_Proposal_Service.php:1436
#, php-format
msgid "Created from %1$s batch %2$s. Final execution remains outside Core."
msgstr "由 %1$s 批次 %2$s 创建。最终执行仍在 Core 之外。"

#. translators: 1: plan ability id, 2: batch id.
#: includes/Governance/Plan_Proposal_Service.php:1624
#, php-format
msgid "Plan batch proposal: %1$s (%2$s)"
msgstr "计划批量提案：%1$s（%2$s）"

#. translators: 1: plan ability id, 2: action count.
#: includes/Governance/Plan_Proposal_Service.php:1630
#, php-format
msgid "Created from %1$s as an ordered batch with %2$d actions. Final execution remains outside Core."
msgstr "由 %1$s 创建为包含 %2$d 个操作的有序批次。最终执行仍在 Core 之外。"

