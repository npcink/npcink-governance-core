#: includes/Governance/Plan_Proposal_Service.php:1001
msgid "Article write plans with blocked claims cannot create proposals."
msgstr "包含被阻止声明的文章写入计划不能创建提案。"

#: includes/Governance/Plan_Proposal_Service.php:1020
msgid "P0 article write plans may target only npcink-abilities-toolkit/create-draft."
msgstr "P0 文章写入计划只能面向 npcink-abilities-toolkit/create-draft。"

#: includes/Governance/Plan_Proposal_Service.php:1030
msgid "Article write plans may create drafts only."
msgstr "文章写入计划只能创建草稿。"

#: includes/Governance/Plan_Proposal_Service.php:1038
msgid "Article write plan input must remain dry-run and must not request commit."
msgstr "文章写入计划输入必须保持试运行，且不得请求提交。"

#: includes/Governance/Plan_Proposal_Service.php:1063
msgid "Article media batch action input must remain dry-run and must not request commit."
msgstr "文章媒体批量操作输入必须保持试运行，且不得请求提交。"

#: includes/Governance/Plan_Proposal_Service.php:1075
msgid "Article media upload actions must include a reviewed media URL."
msgstr "文章媒体上传操作必须包含已审核的媒体 URL。"

#: includes/Governance/Plan_Proposal_Service.php:1089
msgid "Article media metadata actions must include attachment_id or an approved output reference."
msgstr "文章媒体元数据操作必须包含 attachment_id 或已批准的输出引用。"

#: includes/Governance/Plan_Proposal_Service.php:1103
msgid "Article featured-image actions must include post_id or an approved output reference."
msgstr "文章特色图片操作必须包含 post_id 或已批准的输出引用。"

#: includes/Governance/Plan_Proposal_Service.php:1113
msgid "Article featured-image actions must include attachment_id, media_url, or an approved output reference."
msgstr "文章特色图片操作必须包含 attachment_id、media_url 或已批准的输出引用。"

#: includes/Governance/Plan_Proposal_Service.php:1127
msgid "Article inline-image patch actions must include post_id or an approved output reference."
msgstr "文章内联图片补丁操作必须包含 post_id 或已批准的输出引用。"

#: includes/Governance/Plan_Proposal_Service.php:1137
msgid "Article inline-image patch actions must include operations."
msgstr "文章内联图片补丁操作必须包含 operations。"

#. translators: 1: target ability id, 2: action id.
