msgstr "图片候选特色图片操作必须包含 post_id 或已批准的输出引用。"

#: includes/Governance/Plan_Proposal_Service.php:769
msgid "Media optimization plans must declare artifact_type=media_optimization_plan."
msgstr "媒体优化计划必须声明 artifact_type=media_optimization_plan。"

#: includes/Governance/Plan_Proposal_Service.php:777
msgid "Media optimization plans must explicitly request one batch proposal approval."
msgstr "媒体优化计划必须明确请求一个批量提案批准。"

#: includes/Governance/Plan_Proposal_Service.php:786
msgid "Media optimization plans must include metadata and derivative adoption actions."
msgstr "媒体优化计划必须包含元数据和衍生文件采用操作。"

#: includes/Governance/Plan_Proposal_Service.php:801
