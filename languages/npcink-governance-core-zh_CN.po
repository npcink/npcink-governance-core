msgstr "文章批量条目必须是对象。"

#: includes/Governance/Plan_Proposal_Service.php:436
msgid "Article batch write actions must be objects."
msgstr "文章批量写入操作必须是对象。"

#: includes/Governance/Plan_Proposal_Service.php:463
msgid "Article media batch write plans must declare artifact_type=article_media_batch_write_plan."
msgstr "文章媒体批量写入计划必须声明 artifact_type=article_media_batch_write_plan。"

#: includes/Governance/Plan_Proposal_Service.php:471
msgid "Article media batch write plans must explicitly request batch proposal approval."
msgstr "文章媒体批量写入计划必须明确请求批量提案批准。"

#: includes/Governance/Plan_Proposal_Service.php:480
msgid "Article media batch write plans must include 1 to 5 reviewed articles."
msgstr "文章媒体批量写入计划必须包含 1 到 5 篇已审核文章。"

