msgid "Image candidate adoption plans must declare artifact_type=image_candidate_adoption_plan."
msgstr "图片候选采用计划必须声明 artifact_type=image_candidate_adoption_plan。"

#: includes/Governance/Plan_Proposal_Service.php:610
msgid "Image candidate adoption plans must preserve a selected image_candidate.v1 candidate."
msgstr "图片候选采用计划必须保留一个所选 image_candidate.v1 候选项。"

#: includes/Governance/Plan_Proposal_Service.php:619
msgid "Image candidate adoption plans must contain upload, metadata, and optional featured-image actions only."
msgstr "图片候选采用计划只能包含上传、元数据和可选特色图片操作。"

