msgstr "媒体重命名计划只能面向 npcink-abilities-toolkit/rename-media-file。"

#: includes/Governance/Plan_Proposal_Service.php:889
msgid "Media rename plans must target exactly one attachment."
msgstr "媒体重命名计划必须正好面向一个附件。"

#: includes/Governance/Plan_Proposal_Service.php:897
msgid "Media rename plans must include a reviewed target_file_name."
msgstr "媒体重命名计划必须包含已审核的 target_file_name。"

#: includes/Governance/Plan_Proposal_Service.php:905
msgid "Media rename action input must remain dry-run and must not request commit."
msgstr "媒体重命名操作输入必须保持试运行，且不得请求提交。"

#: includes/Governance/Plan_Proposal_Service.php:924
msgid "Article write plans must declare artifact_type=article_write_plan."
msgstr "文章写入计划必须声明 artifact_type=article_write_plan。"

