msgid "Image candidate upload actions must include a reviewed candidate URL."
msgstr "图片候选上传操作必须包含已审核的候选 URL。"

#: includes/Governance/Plan_Proposal_Service.php:708
msgid "Image candidate source_type must be owned, ai_generated, stock, external, or test."
msgstr "图片候选 source_type 必须是 owned、ai_generated、stock、external 或 test。"

#: includes/Governance/Plan_Proposal_Service.php:722
msgid "Image candidate metadata actions must include attachment_id or an approved output reference."
msgstr "图片候选元数据操作必须包含 attachment_id 或已批准的输出引用。"

#: includes/Governance/Plan_Proposal_Service.php:736
