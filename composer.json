{
  "name": "magick-ai/magick-ai-core",
  "description": "WordPress AI operation governance layer for ability intake, proposals, approval boundaries, and audit logs.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4"
  },
  "autoload": {
    "psr-4": {
      "MagickAI\\Core\\": "includes/"
    }
  },
  "scripts": {
    "lint:php": "@php tests/lint.php",
    "smoke:wp": "bash tests/smoke-wp.sh",
    "test": "@php tests/run.php",
    "test:all": [
      "@lint:php",
      "@test"
    ]
  }
}
